  "@type": "CollegeOrUniversity",
  "name": "University of Wollongong",
  "url": "https://www.uow.edu.au/",
  "description": "Public research university based in Wollongong, New South Wales, Australia.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Wollongong",
    "addressRegion": "NSW",
    "addressCountry": "AU"
  },
